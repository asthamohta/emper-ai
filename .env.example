# Database
DATABASE_URL=postgresql://emper:emper_secret@localhost:5432/emper

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Anthropic (chat + context extraction)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Python agent pipeline (izhaar-agents/).
# Run with: cd izhaar-agents && PYTHONPATH=. python3 -m uvicorn src.main:app --port 8000
AGENTS_BASE_URL=http://localhost:8000

# Optional shared secret. When set, src/lib/agents-client.ts adds
# X-Agents-Key on every request and the Python side rejects requests
# without a matching header. Leave blank in local dev (Python's middleware
# bypasses enforcement when its own AGENTS_API_KEY is unset).
AGENTS_API_KEY=
