ANTHROPIC_API_KEY=sk-ant-...

# Optional: connect to the Next.js scraper's Postgres (see ../docker-compose.yml).
# Required only if you want to use the /persona/build/*-from-db endpoints.
SCRAPER_DATABASE_URL=postgresql://emper:emper_secret@localhost:5432/emper

# Optional shared secret enforced on all /api/v1/* routes.
# When unset, the X-Agents-Key dependency is bypassed entirely (dev mode —
# the standalone static UI at / keeps working without any header).
# When set, every /api/v1/* request must include matching X-Agents-Key.
# The healthcheck (/healthz) and the static UI (/, /static/*) are always
# exempt — they live on the app, not the protected router.
AGENTS_API_KEY=
